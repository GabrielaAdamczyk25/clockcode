<div id="grain"></div>

<div id="scroll-container">
  <div id="sticky-scene">

    <div id="clocks-wrapper">
      <div class="clock-outer" id="clock-left">
        <canvas class="clock-canvas" id="canvas-left"></canvas>
      </div>
      <div class="clock-outer" id="clock-right">
        <canvas class="clock-canvas" id="canvas-right"></canvas>
      </div>
    </div>

    <div id="caption-main">
      <p class="title">Perfect Lovers</p>
      <p>Two clocks, set to the same time,<br>slowly drift apart — like all lovers do.<br>After Félix González-Torres, 1991.</p>
    </div>

    <div class="float-caption" id="caption-dali">
      <span class="label">On persistence</span>
      <p>Dalí's melting clocks in <em>The Persistence of Memory</em> dissolved time into landscape. Here, time dissolves into touch — two faces pooling into one another, gravity made of longing.</p>
    </div>

    <div class="float-caption" id="caption-scroll">
      <span class="label">On infinite scroll</span>
      <p>To scroll infinitely is to resist the end. The gesture mimics grief — the same motion, repeated, the same face returning, never quite the same.</p>
    </div>

    <div id="scroll-hint">
      <span>scroll</span>
      <div class="scroll-arrow"></div>
    </div>

  </div>
</div>

<script>
(function() {

  const CLOCK_BASE = Math.min(window.innerWidth * 0.22, window.innerHeight * 0.32, 200);
  const R = Math.max(CLOCK_BASE, 100);
  const DPR = window.devicePixelRatio || 1;
  const SIZE = (R * 2 + 20) * DPR;

  const leftCanvas = document.getElementById('canvas-left');
  const rightCanvas = document.getElementById('canvas-right');
  leftCanvas.width = rightCanvas.width = SIZE;
  leftCanvas.height = rightCanvas.height = SIZE;
  leftCanvas.style.width = rightCanvas.style.width = (R * 2 + 20) + 'px';
  leftCanvas.style.height = rightCanvas.style.height = (R * 2 + 20) + 'px';

  const ctxL = leftCanvas.getContext('2d');
  const ctxR = rightCanvas.getContext('2d');

  let scrollProgress = 0;
  let driftPhase = 0;
  let rafId;
  let lastTime = null;
  let timeOffset = 0;

  function clamp(v,a,b) { return Math.max(a, Math.min(b, v)); }
  function lerp(a, b, t) { return a + (b - a) * t; }

  function drawClock(ctx, time, meltAmount, meltDir, extraWarp, phaseOffset) {
    ctx.save();
    ctx.scale(DPR, DPR);

    const cx = R + 10;
    const cy = R + 10;
    const rOuter = R;

    ctx.clearRect(0, 0, (R * 2 + 20), (R * 2 + 20));

    const m = clamp(meltAmount, 0, 1);
    const w = extraWarp;

    ctx.save();
    ctx.translate(cx, cy);

    const stretch = 1 + m * meltDir * 0.18 + Math.sin(phaseOffset + w * 8) * m * 0.08;
    const squash = 1 / Math.max(stretch, 0.5);
    const tiltX = m * meltDir * 0.12 + Math.cos(phaseOffset * 1.3 + w * 5) * m * 0.1;
    const tiltY = m * 0.08 + Math.sin(phaseOffset * 0.9 + w * 6) * m * 0.06;

    ctx.transform(squash, tiltY * 0.5, tiltX, stretch, 0, m * rOuter * 0.18 * Math.sin(phaseOffset + w * 3));

    ctx.beginPath();
    drawMeltedCircle(ctx, 0, 0, rOuter, m, meltDir, phaseOffset, w);
    ctx.fillStyle = '#f7f3ec';
    ctx.fill();
    ctx.lineWidth = 2.5;
    ctx.strokeStyle = '#2a2420';
    ctx.stroke();

    const innerR = rOuter * 0.88;
    ctx.beginPath();
    drawMeltedCircle(ctx, 0, 0, innerR, m * 0.4, meltDir, phaseOffset + 0.5, w * 0.5);
    ctx.lineWidth = 0.6;
    ctx.strokeStyle = 'rgba(42,36,32,0.15)';
    ctx.stroke();

    for (let i = 0; i < 60; i++) {
      const angle = (i / 60) * Math.PI * 2 - Math.PI / 2;
      const isMajor = i % 5 === 0;
      const wobble = m * (Math.sin(angle * 3 + phaseOffset + w * 4) * 4 + Math.cos(angle * 5 + phaseOffset * 1.2) * 2);
      const r1 = rOuter * (isMajor ? 0.78 : 0.86) + wobble * 0.5;
      const r2 = rOuter * 0.94 + wobble * 0.3;

      ctx.beginPath();
      ctx.moveTo(Math.cos(angle) * r1, Math.sin(angle) * r1);
      ctx.lineTo(Math.cos(angle) * r2, Math.sin(angle) * r2);
      ctx.lineWidth = isMajor ? 2.0 : 0.8;
      ctx.strokeStyle = isMajor ? 'rgba(26,22,18,0.85)' : 'rgba(26,22,18,0.4)';
      ctx.stroke();

      if (isMajor) {
        const numR = rOuter * 0.64 + wobble * 0.3;
        const num = i === 0 ? 12 : i / 5;
        const numAngle = angle + m * Math.sin(angle * 2 + phaseOffset) * 0.15;
        ctx.save();
        ctx.translate(Math.cos(numAngle) * numR, Math.sin(numAngle) * numR);
        ctx.rotate(m * Math.sin(angle * 3 + phaseOffset) * 0.3);
        ctx.font = `${rOuter * 0.13}px 'Cormorant Garamond', Georgia, serif`;
        ctx.fillStyle = `rgba(26,22,18,${lerp(0.85, 0.3, m * 0.7)})`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(num, 0, 0);
        ctx.restore();
      }
    }

    const now = time;
    const sec = now.seconds + now.milliseconds / 1000;
    const min = now.minutes + sec / 60;
    const hr = (now.hours % 12) + min / 60;

    const secAngle = (sec / 60) * Math.PI * 2 - Math.PI / 2;
    const minAngle = (min / 60) * Math.PI * 2 - Math.PI / 2;
    const hrAngle = (hr / 12) * Math.PI * 2 - Math.PI / 2;

    drawHand(ctx, hrAngle, rOuter * 0.52, rOuter * 0.022, 'rgba(26,22,18,0.92)', m, phaseOffset, w, 'hour');
    drawHand(ctx, minAngle, rOuter * 0.72, rOuter * 0.016, 'rgba(26,22,18,0.85)', m, phaseOffset + 1, w, 'min');
    drawSecondHand(ctx, secAngle, rOuter * 0.82, rOuter * 0.008, m, phaseOffset, w);

    ctx.beginPath();
    ctx.arc(0, 0, rOuter * 0.025, 0, Math.PI * 2);
    ctx.fillStyle = '#2a2420';
    ctx.fill();

    ctx.restore();
    ctx.restore();
  }

  function drawMeltedCircle(ctx, cx, cy, r, melt, dir, phase, warp) {
    const steps = 80;
    ctx.beginPath();
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const angle = t * Math.PI * 2 - Math.PI / 2;
      const wobble = melt * r * (
        0.06 * Math.sin(angle * 2 + phase) +
        0.04 * Math.sin(angle * 3 + phase * 1.4) +
        0.03 * Math.cos(angle * 4 + phase * 0.8) +
        0.08 * Math.pow(Math.max(0, Math.sin(angle + Math.PI / 2)), 2) * (1 + warp * 2) +
        warp * 0.12 * Math.sin(angle * 5 + phase * 2)
      );
      const droop = melt * r * 0.12 * Math.pow(Math.max(0, Math.sin(angle - Math.PI / 2)), 3) * (1 + warp);
      const rr = r + wobble + droop;
      const px = cx + Math.cos(angle) * rr;
      const py = cy + Math.sin(angle) * rr;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.closePath();
  }

  function drawHand(ctx, angle, length, width, color, melt, phase, warp, type) {
    ctx.save();
    ctx.rotate(angle);
    const droop = melt * length * (type === 'hour' ? 0.22 : 0.30);
    const waver = melt * length * 0.08 * Math.sin(phase + warp * 4);
    ctx.beginPath();
    ctx.moveTo(0, 0);
    const cp1x = length * 0.3 + waver * 0.5;
    const cp1y = droop * 0.4;
    const cp2x = length * 0.6 + waver;
    const cp2y = droop * 0.8;
    const ex = length + waver * 0.3;
    const ey = droop;
    ctx.bezierCurveTo(cp1x, cp1y, cp2x, cp2y, ex, ey);
    ctx.lineWidth = width * (1 + melt * 0.4);
    ctx.strokeStyle = color;
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.restore();
  }

  function drawSecondHand(ctx, angle, length, width, melt, phase, warp) {
    ctx.save();
    ctx.rotate(angle);
    const droop = melt * length * 0.45;
    const waver = melt * length * 0.15 * Math.sin(phase * 1.5 + warp * 6);
    ctx.beginPath();
    ctx.moveTo(0, -length * 0.15);
    ctx.bezierCurveTo(
      length * 0.3 + waver, droop * 0.3,
      length * 0.65 + waver * 1.5, droop * 0.75,
      length + waver * 0.5, droop
    );
    ctx.lineWidth = width;
    ctx.strokeStyle = 'rgba(160,60,40,0.85)';
    ctx.lineCap = 'round';
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(0, 0, length * 0.06, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(160,60,40,0.85)';
    ctx.fill();
    ctx.restore();
  }

  function getTime(offset) {
    const d = new Date(Date.now() + offset);
    return {
      hours: d.getHours(),
      minutes: d.getMinutes(),
      seconds: d.getSeconds(),
      milliseconds: d.getMilliseconds()
    };
  }

  let scrollY = window.scrollY;
  let targetScrollY = window.scrollY;

  window.addEventListener('scroll', () => {
    targetScrollY = window.scrollY;
    if (targetScrollY < 10) {
      document.getElementById('scroll-hint').classList.remove('hidden');
    } else {
      document.getElementById('scroll-hint').classList.add('hidden');
    }
  }, { passive: true });

  function computeMelt(progress) {
    const raw = progress * 5;
    const wave = Math.abs(Math.sin(raw * Math.PI));
    const base = clamp(progress * 2.5, 0, 1);
    return clamp(base * 0.4 + wave * 0.6 * base, 0, 0.98);
  }

  function loop(ts) {
    rafId = requestAnimationFrame(loop);
    if (!lastTime) lastTime = ts;
    const dt = (ts - lastTime) / 1000;
    lastTime = ts;

    scrollY += (targetScrollY - scrollY) * 0.08;
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    scrollProgress = maxScroll > 0 ? scrollY / maxScroll : 0;

    driftPhase += dt * 0.4;
    timeOffset += dt * 2200;

    const rawProgress = scrollProgress;
    const melt = computeMelt(rawProgress);

    const warpPhase = rawProgress * Math.PI * 12;
    const extraWarp = rawProgress > 0.05 ? Math.abs(Math.sin(warpPhase)) * rawProgress : 0;

    const timeL = getTime(0);
    const timeR = getTime(timeOffset);

    drawClock(ctxL, timeL, melt, -1, extraWarp, driftPhase);
    drawClock(ctxR, timeR, melt, 1, extraWarp, driftPhase + 1.3);

    const daliCaption = document.getElementById('caption-dali');
    const scrollCaption = document.getElementById('caption-scroll');
    const mainCaption = document.getElementById('caption-main');

    const daliThreshold = 0.08;
    const scrollThreshold = 0.22;

    if (rawProgress > daliThreshold) {
      daliCaption.classList.add('visible');
    } else {
      daliCaption.classList.remove('visible');
    }

    if (rawProgress > scrollThreshold) {
      scrollCaption.classList.add('visible');
      mainCaption.style.opacity = clamp(1 - (rawProgress - 0.22) * 3, 0, 1).toString();
    } else {
      scrollCaption.classList.remove('visible');
      mainCaption.style.opacity = '1';
    }
  }

  rafId = requestAnimationFrame(loop);

})();
</script>
</body>
</html>
